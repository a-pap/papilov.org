/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: interest-cohort=()

/*.html
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/css/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.svg
  Cache-Control: public, max-age=31536000, immutable

/img/*
  Cache-Control: public, max-age=2592000

/research/*/infographic.html
  X-Frame-Options: SAMEORIGIN
  Cache-Control: public, max-age=86400

/llms.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400
  X-Robots-Tag: all
  Link: </llms-full.txt>; rel="alternate"; type="text/plain"; title="Full content"

/llms-full.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400
  X-Robots-Tag: all

/memex/llms.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400
  X-Robots-Tag: all
  Link: </memex/llms-full.txt>; rel="alternate"; type="text/plain"; title="MEMEX full guide"

/memex/llms-full.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400
  X-Robots-Tag: all

/memex/
  X-Robots-Tag: all, max-snippet:-1, max-image-preview:large
  Link: </memex/llms.txt>; rel="describedby"; type="text/plain"

/.well-known/ai-plugin.json
  Content-Type: application/json; charset=utf-8
  Cache-Control: public, max-age=86400
  Access-Control-Allow-Origin: *

/research/*
  X-Robots-Tag: all, max-snippet:-1, max-image-preview:large
  Link: </llms.txt>; rel="describedby"; type="text/plain"

/*.txt
  Cache-Control: public, max-age=86400

/sitemap.xml
  Cache-Control: public, max-age=3600

/*/sitemap.xml
  Cache-Control: public, max-age=3600
